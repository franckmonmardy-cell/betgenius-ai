{
  "version": 2,
  "name": "betgenius-ai",
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/fixtures",
      "dest": "/api/fixtures.js"
    },
    {
      "src": "/api/live",
      "dest": "/api/live.js"
    },
    {
      "src": "/api/predictions",
      "dest": "/api/predictions.js"
    },
    {
      "src": "/api/status",
      "dest": "/api/status.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
